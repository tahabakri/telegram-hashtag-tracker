# Telegram bot token from @BotFather (required)
BOT_TOKEN=your-telegram-bot-token-here

# Campaign hashtags to track — comma-separated (case-insensitive, whole-word).
TRACKED_HASHTAGS=#entry,#proof,#prediction

# Optional: replies per hashtag as a one-line JSON object. Blank = built-in
# defaults. Example:
# REPLIES_JSON={"#entry":["You're in!","Logged"],"#proof":["Got it"]}
REPLIES_JSON=

# Optional — only needed for the /stats command.
# Your group's chat ID (see README for how to find it).
GROUP_CHAT_ID=0

# Optional — Google Sheets logging. Leave false to log to CSV only.
USE_GOOGLE_SHEETS=false
GSHEET_NAME=Campaign Entries

# Google Sheets credentials.
# - Cloud hosting (e.g. Railway): paste the ENTIRE service-account JSON here.
# - Local dev: leave blank and use a creds.json file next to bot.py.
GOOGLE_CREDS_JSON=
